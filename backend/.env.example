# Server
PORT=5000
NODE_ENV=development

# PostgreSQL Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/brassflow_db?schema=public"

# JWT Authentication (change these secrets before deploying to production!)
JWT_SECRET="super-secret-jwt-key-change-in-production-12345"
JWT_EXPIRES_IN="1d"
JWT_REFRESH_SECRET="super-secret-refresh-key-change-in-production-12345"
JWT_REFRESH_EXPIRES_IN="7d"

# Redis Cache
REDIS_URL="redis://localhost:6379"

# SMTP Email — Fallback only. Configure properly from the Settings tab inside the app.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-gmail@gmail.com"
SMTP_PASS="your-16-digit-app-password"
SMTP_FROM="BrassFlow AI <your-gmail@gmail.com>"
